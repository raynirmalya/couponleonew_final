{
  "manifest_version": 3,
  "name": "CouponLeo Companion",
  "version": "0.1.4",
  "description": "Shows CouponLeo coupons and deals for the store you are visiting.",
  "action": {
    "default_title": "CouponLeo",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/toolbar-icon.png",
      "32": "assets/toolbar-icon.png",
      "48": "assets/toolbar-icon.png",
      "128": "assets/toolbar-icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://couponleo.com/*",
    "https://www.couponleo.com/*",
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5001/*",
    "http://localhost:5001/*",
    "http://127.0.0.1:4300/*",
    "http://localhost:4300/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:5173/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "https://couponleo.com/*",
        "https://www.couponleo.com/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*",
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:5173/*"
      ],
      "js": [
        "shared.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/toolbar-icon.png",
    "32": "assets/toolbar-icon.png",
    "48": "assets/toolbar-icon.png",
    "128": "assets/toolbar-icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "couponleo@couponleo.com",
      "strict_min_version": "121.0"
    }
  }
}
